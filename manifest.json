{
  "manifest_version": 3,
  "name": "Git Copy Helper",
  "version": "1.0",
  "description": "Adds copy buttons to GitHub links",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["nav-tab.js", "deploy-buttons.js", "content.js"],
      "run_at": "document_end"
    }
  ],
  "permissions": ["clipboardWrite", "activeTab", "storage"],
  "host_permissions": ["https://api.github.com/*"]
}

